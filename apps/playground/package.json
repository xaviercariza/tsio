{
  "name": "@tsio/playground",
  "description": "tsio playground app",
  "private": true,
  "version": "0.0.3",
  "scripts": {
    "start": "pnpm --filter @tsio/core build && pnpm --filter @tsio/socketio build && tsx src/server.ts",
    "types-check": "tsc --noemit",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build"
  },
  "dependencies": {
    "@tsio/core": "workspace:^",
    "@tsio/socketio": "workspace:^",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "nodemon": "^3.1.14",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
