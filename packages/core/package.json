{
  "name": "@tsio/core",
  "description": "Core package of tsio",
  "keywords": [],
  "license": "MIT",
  "author": "Xavier Cardona",
  "version": "0.1.0",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prettier": "prettier --write src/**/*.ts --config ../../prettier.config.cjs",
    "types-check": "tsc --noemit"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "pipe-ts": "^0.0.9"
  },
  "peerDependencies": {
    "zod": "^3.22.4 || ^4.0.0"
  }
}
