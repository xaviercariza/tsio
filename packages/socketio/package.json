{
  "name": "@tsio/socketio",
  "description": "Socket.io adapters for tsio",
  "keywords": [],
  "license": "MIT",
  "author": "Xavier Cardona",
  "version": "0.0.3",
  "exports": {
    "./package.json": "./package.json",
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": ["dist/client.d.ts"],
      "server": ["dist/server.d.ts"]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prettier": "prettier --write src/**/*.ts --config ../../prettier.config.cjs",
    "types-check": "tsc --noemit"
  },
  "dependencies": {
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@tsio/core": "workspace:^",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "tsup": "^8.0.1",
    "typescript": "^5.4.2"
  },
  "peerDependencies": {
    "@tsio/core": "workspace:^",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4"
  }
}
