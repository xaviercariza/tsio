{
  "name": "@tsio/socketio",
  "description": "Socket.io adapters for tsio",
  "keywords": [],
  "license": "MIT",
  "author": "Xavier Cardona",
  "version": "0.1.0",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ],
      "server": [
        "dist/server.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prettier": "prettier --write src/**/*.ts --config ../../prettier.config.cjs",
    "types-check": "tsc --noemit"
  },
  "dependencies": {},
  "devDependencies": {
    "@tsio/core": "workspace:^",
    "@types/node": "^24.13.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@tsio/core": "^0.0.3 || ^0.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
